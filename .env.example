# Copy to `.env` for local dev. On production (Netlify/Vercel/etc.), set the same keys in the host dashboard
# and redeploy. All keys are PUBLIC_* (safe in the browser). Code fallbacks live in src/constants/*.ts — see README.

# --- Forms (Google Forms) ---
PUBLIC_ALUMNI_FORM_URL=https://forms.gle/QFdBhxvbyLAvPft79
PUBLIC_JOIN_INTEREST_FORM_URL=https://forms.gle/ZpwFMvWHdZktbLcw8
PUBLIC_PERFORMANCE_REQUEST_FORM_URL=https://forms.gle/Q5WzKaTK2DPijQHHA

# --- Contact ---
PUBLIC_SUPPORT_EMAIL=utxhum@gmail.com

# --- Donations (/support) — use public donate URLs, not organizer /manage/ links ---
PUBLIC_DONATE_VENMO_URL=https://venmo.com/u/humacappella
# Public campaign page (e.g. https://www.gofundme.com/f/your-campaign or https://gofund.me/xxxx)
PUBLIC_DONATE_GOFUNDME_URL=https://www.gofundme.com/f/celebrate-25-years-with-hum-a-cappellas-new-album
# Leave empty to show “PayPal coming soon” on Support
PUBLIC_DONATE_PAYPAL_URL=

# --- YouTube ---
PUBLIC_YOUTUBE_CHANNEL_URL=https://www.youtube.com/utxhum
# Comma-separated video IDs for home “Watch us” (no URLs)
PUBLIC_YOUTUBE_FEATURED_IDS=eZ8ZEm5Xews,6DNmgi2mGp4,Bdy2bQ7dLAU
# Home hype reel — YouTube video ID only (not the full watch URL)
PUBLIC_HOME_HYPE_VIDEO_YOUTUBE_ID=qjyw5qyAvRk

# --- Instagram ---
PUBLIC_INSTAGRAM_URL=https://www.instagram.com/humacappella/
# Fouita (or similar) embed iframe src — not the instagram.com profile URL
PUBLIC_INSTAGRAM_FEED_EMBED_URL=https://emb.fouita.com/widget/0x453851/ftxwxc2ryi

