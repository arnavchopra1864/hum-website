---
const blocks = [
	{
		title: 'Performances & gigs',
		body: 'From campus showcases to local gigs to national shows, we bring high-energy music to every stage.',
	},
	{
		title: 'National competition',
		body: 'Across the nation, we pride ourselves on competing at the highest levels, and we have the hardware to prove it.',
	},
	{
		title: 'Community & culture',
		body: 'Late nights, inside jokes, lifelong friends. Join for the music, stay for the humily.',
	},
	{
		title: 'Alumni legacy',
		body: 'Our story spans decades of talent. Our alumni are singers, musicians, and music lovers spread across the country.',
	},
] as const;
---

<section class="border-b border-black/10 py-16 sm:py-24" aria-labelledby="what-we-do-heading">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<h2 id="what-we-do-heading" class="font-heading text-3xl font-bold text-hum-black sm:text-4xl">
			What we do
		</h2>
		<p class="mt-3 max-w-3xl text-black/60">Short version: we perform, compete, build community, and honor everyone who came before us.</p>
		<ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
			{
				blocks.map((b) => (
					<li class="rounded-xl border border-black/10 bg-white p-6 shadow-sm">
						<h3 class="font-heading text-lg font-bold text-hum-black">{b.title}</h3>
						<p class="mt-3 text-sm leading-relaxed text-black/75">{b.body}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
