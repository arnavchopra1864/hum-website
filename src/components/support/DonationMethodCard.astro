---
interface Props {
	title: string;
	description: string;
	url?: string;
	buttonLabel: string;
	comingSoonLabel?: string;
}

const { title, description, url, buttonLabel, comingSoonLabel = 'Coming soon' } = Astro.props;
const isActive = typeof url === 'string' && url.trim().length > 0;
---

<article class="rounded-xl border border-black/10 bg-white p-6 shadow-sm">
	<h3 class="font-heading text-xl font-bold text-hum-black">{title}</h3>
	<p class="mt-3 text-sm leading-relaxed text-black/75">{description}</p>

	{
		isActive ? (
			<a
				href={url}
				target="_blank"
				rel="noopener noreferrer"
				class="mt-5 inline-flex min-h-[44px] items-center justify-center rounded-md bg-hum-black px-4 py-2 text-sm font-semibold text-hum-white transition-colors hover:bg-black/90"
			>
				{buttonLabel}
			</a>
		) : (
			<p class="mt-5 inline-flex min-h-[44px] items-center rounded-md border border-dashed border-black/30 px-4 py-2 text-sm font-semibold text-black/55">
				{comingSoonLabel}
			</p>
		)
	}
</article>
