---
type Props = {
	/** Matches `aria-labelledby` on the section. */
	id: string;
	/** Bold Fraunces line (or full title when `titleEmphasis` is omitted). */
	titleLead: string;
	/** Optional italic second line — music / alumni split headline. */
	titleEmphasis?: string;
	/** Muted intro below the title. */
	intro?: string;
	/** `action` keeps the green gradient and room for hero CTAs via the default slot. */
	variant?: 'editorial' | 'action';
};

const { id, titleLead, titleEmphasis, intro, variant = 'editorial' } = Astro.props;
const hasActions = Astro.slots.has('default');
---

<section
	class:list={[
		'border-b border-black/10',
		variant === 'action'
			? 'bg-gradient-to-b from-hum-green/15 to-transparent'
			: 'bg-hum-white',
	]}
	aria-labelledby={id}
>
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
		<div class="max-w-3xl">
			<h1
				{id}
				class="font-heading text-[clamp(2rem,5vw,3rem)] font-bold leading-[1.15] tracking-tight text-hum-black"
			>
				{titleLead}
				{
					titleEmphasis ? (
						<>
							<br />
							<em class="font-normal italic text-black/45">{titleEmphasis}</em>
						</>
					) : null
				}
			</h1>
			{intro ? (
				<p class="mt-3 max-w-xl text-[0.9375rem] leading-[1.7] text-black/55 sm:text-base">{intro}</p>
			) : null}
			{
				hasActions ? (
					<div class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
						<slot />
					</div>
				) : null
			}
		</div>
	</div>
</section>
